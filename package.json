{
  "name": "smashdown",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "wrangler dev --remote --var AUTH0_DOMAIN:$VITE_AUTH0_DOMAIN",
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "build": "vite build",
    "deploy": "run-s build deploy:worker",
    "deploy:worker": "wrangler deploy",
    "push-secrets": "echo $VITE_AUTH0_DOMAIN | npx wrangler secret put AUTH0_DOMAIN",
    "style": "prettier  --write \"src/**/*.{ts,tsx}\"",
    "style:ci": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "type": "module",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/postcss": "^4.0.17",
    "@trpc/server": "^11.0.0",
    "@types/lodash": "^4.14.191",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.19",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.0.17",
    "tailwindcss-safe-area": "^0.2.2",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-solid": "^2.11.6",
    "wrangler": "^4.77.0"
  },
  "dependencies": {
    "@auth0/auth0-spa-js": "^2.1.3",
    "@solid-primitives/map": "^0.6.0",
    "@solidjs/router": "^0.15.3",
    "@std/ulid": "npm:@jsr/std__ulid@1.0.0-rc.4",
    "@thisbeyond/solid-select": "^0.15.0",
    "@trpc/client": "^11.0.0",
    "classnames": "^2.3.2",
    "copy-to-clipboard": "^3.3.3",
    "date-fns": "^2.29.3",
    "hono": "^4.7.7",
    "jose": "^5.10.0",
    "lodash": "^4.17.21",
    "nanoid": "^5.1.5",
    "solid-forms": "^0.4.6",
    "solid-js": "^1.9.5",
    "solid-toast": "^0.5.0",
    "store2": "^2.14.2",
    "superjson": "^2.2.2",
    "url-join": "^5.0.0",
    "zod": "^3.24.2"
  },
  "engines": {
    "node": ">=16"
  }
}
